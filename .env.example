# Database (Neon Cloud PostgreSQL)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth Configuration
# NEXTAUTH_URL: Your production URL (e.g., https://buildsync.vercel.app)
NEXTAUTH_URL="https://your-app.vercel.app"

# NEXTAUTH_SECRET: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-generate-with-openssl"

# Google OAuth (optional)
# Get credentials from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Resend Email Service
RESEND_API_KEY=
EMAIL_FROM=BuildSync <onboarding@resend.dev>

# Application URL
APP_URL=http://localhost:3000

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=

# Anthropic AI
ANTHROPIC_API_KEY=

# Load Generator uses 100% free services — no API keys required:
#   • Map tiles: CartoDB Dark Matter (OpenStreetMap) — no signup, no key
#   • Geocoding: Nominatim (OSM) — no key, polite User-Agent
#   • Elevation: Open-Elevation — no key, best-effort
# If those services are rate-limiting you at scale, swap them for paid
# equivalents (Google Maps, MapTiler, Mapbox) in:
#   - src/components/ttc/load-gen/SiteMap.tsx
#   - src/app/api/load-gen/geocode/route.ts
#   - src/app/api/load-gen/elevation/route.ts
